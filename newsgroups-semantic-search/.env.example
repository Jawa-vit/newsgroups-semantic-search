# Copy this to .env and customise
# (the application reads these via os.getenv() in app/config.py)

# Embedding model (HuggingFace model name)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of fuzzy clusters (justified by silhouette analysis — see README)
N_CLUSTERS=15

# FCM fuzziness exponent (m=2.0 is canonical; m→1 = hard k-means; m→∞ = noise)
FCM_FUZZINESS=2.0

# PCA dimensions before FCM (reduces 384-d to this; ~85% variance retained at 64)
PCA_COMPONENTS=64

# ── THE KEY TUNABLE ──────────────────────────────────────────────────────────
# Cosine similarity threshold for cache hits.
# Lower = more hits, less precise. Higher = fewer hits, more precise.
# 0.70 = broad paraphrase matching
# 0.85 = default (near-identical phrasing)
# 0.95 = near-exact match only
CACHE_SIMILARITY_THRESHOLD=0.85

# Number of cluster buckets searched on each cache lookup
# 2 covers ~99% of cases (queries rarely straddle >2 clusters strongly)
CACHE_CLUSTER_SEARCH_DEPTH=2

# Documents returned per semantic search query
TOP_K_RESULTS=5
